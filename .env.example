# Coffee Guardian Frontend Environment Variables
# Note: In Vite, variables must start with VITE_ to be exposed to the browser

# Backend API URL (Flask server with SQLite for auth & database)
# For local development: http://localhost:5001
# For Render production: https://coffee-guardian-api.onrender.com
VITE_API_URL=http://localhost:5001

# ML API URL (Hugging Face Space or local ML model server for disease detection)
# For local development: http://localhost:5000
# For Hugging Face: https://yourusername-coffee-disease.hf.space
VITE_ML_API_URL=http://localhost:5000

# Enable mock ML predictions (set to 'true' when ML API is unavailable)
VITE_USE_MOCK_ML=false
# Enable debug mode
VITE_DEBUG=false
