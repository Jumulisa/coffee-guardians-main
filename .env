# Coffee Guardian Frontend Environment Variables

# Backend API URL (Flask server for auth & database)
VITE_API_URL=http://localhost:5001

# ML API URL (Hugging Face Spaces)
VITE_ML_API_URL=https://badgirlriri-coffeeguard-ai.hf.space

# Enable mock ML predictions (set to 'true' when ML API is unavailable)
VITE_USE_MOCK_ML=false

# Enable debug mode
VITE_DEBUG=false
